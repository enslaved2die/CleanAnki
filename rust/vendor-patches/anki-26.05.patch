+    /// produces (see docs/ARCHITECTURE.md §17), so its `.send()` cannot link.
+    /// Instead we extract the built request's method/url/headers with reqwest
+    /// (that part is pure Rust and links fine) and perform the actual HTTP I/O
+    /// with Emscripten's own native `emscripten_fetch` C API in its
+    /// **synchronous** mode.
+    ///
+    /// Synchronous `emscripten_fetch` blocks the calling thread on network I/O,
+    /// which the browser forbids on the main thread — so this must only ever be
+    /// reached from the background worker thread the bridge spawns to drive the
+    /// whole sync (`wasm_sync_*` in rust/wasm-bridge/src/main.rs run
+    /// `block_on(NormalSyncer::sync())` on a `std::thread`). Being on that
+    /// worker, blocking here is legal and correct, so no further thread hop is
+    /// needed. This is a deliberate simplification of the streaming/timeout
+    /// monitor above: the request/response bodies are zstd-encoded in one shot
+    /// (standard zstd frames, wire-compatible with the server's
+    /// `async_compression` streaming zstd) rather than incrementally, and the
+    /// stall-timeout race is replaced by `emscripten_fetch`'s own
+    /// `timeoutMSecs`. See docs/ARCHITECTURE.md §20.
+    #[cfg(target_family = "wasm")]
+    pub async fn zstd_request_with_timeout(
+        &self,
+        request: RequestBuilder,
+        request_body: Vec<u8>,
+        stall_duration: Duration,
+    ) -> HttpResult<Vec<u8>> {
+        use std::ffi::CString;
+        use std::os::raw::c_char;
+
+        let built = request
+            .header(CONTENT_TYPE, "application/octet-stream")
+            .build()
+            .or_http_err(StatusCode::BAD_REQUEST, "building request")?;
+
+        let method = CString::new(built.method().as_str())
+            .or_http_err(StatusCode::BAD_REQUEST, "method")?;
+        let url = CString::new(built.url().as_str())
+            .or_http_err(StatusCode::BAD_REQUEST, "url")?;
+
+        // emscripten wants a null-terminated {k1,v1,k2,v2,...,0} array. Keep the
+        // backing CStrings alive for the whole (synchronous) fetch call.
+        let mut header_cstrings: Vec<CString> = Vec::new();
+        for (name, value) in built.headers().iter() {
+            let v = value
+                .to_str()
+                .or_http_err(StatusCode::BAD_REQUEST, "non-utf8 header value")?;
+            header_cstrings
+                .push(CString::new(name.as_str()).or_http_err(StatusCode::BAD_REQUEST, "header name")?);
+            header_cstrings
+                .push(CString::new(v).or_http_err(StatusCode::BAD_REQUEST, "header value")?);
+        }
+        let mut header_ptrs: Vec<*const c_char> =
+            header_cstrings.iter().map(|c| c.as_ptr()).collect();
+        header_ptrs.push(std::ptr::null());
+
+        // Compress the request body up front (level 0 = zstd's default). The
+        // level is irrelevant to the server, which just decompresses.
+        let compressed = zstd::encode_all(Cursor::new(request_body), 0)
+            .or_http_err(StatusCode::INTERNAL_SERVER_ERROR, "zstd encode request")?;
+
+        // SAFETY: all pointers below outlive the synchronous emscripten_fetch
+        // call (it blocks until the transfer finishes), and the response struct
+        // is closed before we return.
+        let (status, body) = unsafe {
+            let mut attr: emfetch::FetchAttr = std::mem::zeroed();
+            emfetch::emscripten_fetch_attr_init(&mut attr);
+            let method_bytes = method.as_bytes_with_nul();
+            attr.request_method[..method_bytes.len()]
+                .copy_from_slice(std::slice::from_raw_parts(
+                    method_bytes.as_ptr() as *const c_char,
+                    method_bytes.len(),
+                ));
+            attr.attributes =
+                emfetch::EMSCRIPTEN_FETCH_LOAD_TO_MEMORY | emfetch::EMSCRIPTEN_FETCH_SYNCHRONOUS;
+            attr.timeout_msecs = stall_duration.as_millis() as u32;
+            attr.request_headers = header_ptrs.as_ptr();
+            attr.request_data = compressed.as_ptr() as *const c_char;
+            attr.request_data_size = compressed.len();
+
+            let fetch = emfetch::emscripten_fetch(&mut attr, url.as_ptr());
+            if fetch.is_null() {
+                return Err(HttpError {
+                    code: StatusCode::SEE_OTHER,
+                    context: "emscripten_fetch returned null".into(),
+                    source: None,
+                });
+            }
+            let status = (*fetch).status;
+            let n = (*fetch).num_bytes as usize;
+            let body = if !(*fetch).data.is_null() && n > 0 {
+                std::slice::from_raw_parts((*fetch).data as *const u8, n).to_vec()
+            } else {
+                Vec::new()
+            };
+            emfetch::emscripten_fetch_close(fetch);
+            (status, body)
+        };
+
+        let code = StatusCode::from_u16(status).unwrap_or(StatusCode::SEE_OTHER);
+        if !code.is_success() {
+            // status 0 = network error / CORS block / timeout (XHR reports no
+            // HTTP status); surface it rather than trying to zstd-decode noise.
+            return Err(HttpError {
+                code: if status == 0 { StatusCode::SEE_OTHER } else { code },
+                context: format!("sync server returned HTTP {status}"),
+                source: None,
+            });
+        }
+
+        zstd::decode_all(body.as_slice())
+            .or_http_err(StatusCode::SEE_OTHER, "zstd decode response")
+    }
+}
+
+/// Raw FFI to Emscripten's native `emscripten_fetch` HTTP API (linked via
+/// `-sFETCH=1`, see rust/wasm-bridge/build.rs). Field order/types mirror
+/// `emscripten/fetch.h` exactly so `#[repr(C)]` matches the C ABI. Only the
+/// wasm sync transport above uses this.
+#[cfg(target_family = "wasm")]
+mod emfetch {
+    use std::os::raw::c_char;
+    use std::os::raw::c_void;
+
+    pub const EMSCRIPTEN_FETCH_LOAD_TO_MEMORY: u32 = 1;
+    pub const EMSCRIPTEN_FETCH_SYNCHRONOUS: u32 = 64;
+
+    #[repr(C)]
+    pub struct FetchAttr {
+        pub request_method: [c_char; 32],
+        pub user_data: *mut c_void,
+        pub onsuccess: Option<extern "C" fn(*mut Fetch)>,
+        pub onerror: Option<extern "C" fn(*mut Fetch)>,
+        pub onprogress: Option<extern "C" fn(*mut Fetch)>,
+        pub onreadystatechange: Option<extern "C" fn(*mut Fetch)>,
+        pub attributes: u32,
+        pub timeout_msecs: u32,
+        pub with_credentials: bool,
+        pub destination_path: *const c_char,
+        pub user_name: *const c_char,
+        pub password: *const c_char,
+        pub request_headers: *const *const c_char,
+        pub overridden_mime_type: *const c_char,
+        pub request_data: *const c_char,
+        pub request_data_size: usize,
+    }
+
+    #[repr(C)]
+    pub struct Fetch {
+        pub id: u32,
+        pub user_data: *mut c_void,
+        pub url: *const c_char,
+        pub data: *const c_char,
+        pub num_bytes: u64,
+        pub data_offset: u64,
+        pub total_bytes: u64,
+        pub ready_state: u16,
+        pub status: u16,
+        pub status_text: [c_char; 64],
+        pub __attributes: FetchAttr,
+        pub response_url: *const c_char,
+    }
+
+    extern "C" {
+        pub fn emscripten_fetch_attr_init(attr: *mut FetchAttr);
+        pub fn emscripten_fetch(attr: *mut FetchAttr, url: *const c_char) -> *mut Fetch;
+        pub fn emscripten_fetch_close(fetch: *mut Fetch) -> i32;
+    }
 }
 
