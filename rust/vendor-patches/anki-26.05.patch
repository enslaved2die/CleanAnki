+
+    /// WASM SPIKE (CleanAnki): reqwest's wasm fetch backend has no streaming
+    /// `Body::wrap_stream`, and its response streams are `!Send`, so the
+    /// streaming monitor above cannot compile for wasm. Sync is never invoked
+    /// from the wasm bridge, so this stub just returns an error.
+    #[cfg(target_family = "wasm")]
+    pub async fn zstd_request_with_timeout(
+        &self,
+        _request: RequestBuilder,
+        _request_body: Vec<u8>,
+        _stall_duration: Duration,
+    ) -> HttpResult<Vec<u8>> {
+        Err(HttpError {
+            code: StatusCode::NOT_IMPLEMENTED,
+            context: "sync transport is unavailable in the wasm build".into(),
+            source: None,
+        })
+    }
 }
 
