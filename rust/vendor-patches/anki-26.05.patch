diff --git a/rslib/Cargo.toml b/rslib/Cargo.toml
index eac2c14..4cb0dc6 100644
--- a/rslib/Cargo.toml
+++ b/rslib/Cargo.toml
@@ -10,9 +10,20 @@ workspace = ".."
 description = "Anki's Rust library code"
 
 [features]
+default = ["sync-server"]
 bench = ["criterion"]
 rustls = ["reqwest/rustls-tls", "reqwest/rustls-tls-native-roots"]
 native-tls = ["reqwest/native-tls"]
+# WASM SPIKE (CleanAnki): gates the embedded sync HTTP *server* (the only code
+# using axum::serve + tokio::net::TcpListener + tokio::signal). Those pull
+# tokio's `net`/`signal` features, which drag in `mio`, whose build contains a
+# hard `compile_error!` on wasm targets. Disabling this feature (the wasm bridge
+# sets default-features=false) drops mio while KEEPING the reqwest-based sync
+# *client* and every shared sync data type (Graves, MediaDatabase, progress,
+# sanity counts, error variants) that core storage/media/progress depend on.
+# Native/desktop consumers keep it via `default`, so their behaviour is
+# unchanged. See docs/ARCHITECTURE.md (2026-07-10 section).
+sync-server = ["tokio/signal", "axum/tokio", "axum-client-ip/connect-info"]
 
 [[bench]]
 name = "benchmark"
@@ -45,8 +56,14 @@ anki_io.workspace = true
 anki_proto.workspace = true
 async-compression.workspace = true
 async-trait.workspace = true
-axum.workspace = true
-axum-client-ip.workspace = true
+# WASM SPIKE: overridden from workspace to drop the `tokio` default feature
+# (which enables tokio/net -> mio). Re-added under the `sync-server` feature.
+axum = { version = "0.8.4", default-features = false, features = ["multipart", "macros", "form", "http1", "json", "matched-path", "original-uri", "query", "tower-log", "tracing"] }
+# WASM SPIKE: overridden to drop `connect-info` (which enables axum/tokio ->
+# tokio/net -> mio). Re-added under the `sync-server` feature.
+# Bumped from workspace 1.1.3 -> 1.3.x: 1.1.3 pulls axum/tokio unconditionally,
+# whereas 1.3.x gates it behind the `connect-info` feature (re-added under sync-server).
+axum-client-ip = { version = "1.3", default-features = false, features = ["serde"] }
 axum-extra.workspace = true
 bitflags.workspace = true
 blake3.workspace = true
@@ -99,7 +116,10 @@ sha2.workspace = true
 snafu.workspace = true
 strum.workspace = true
 tempfile.workspace = true
-tokio.workspace = true
+# WASM SPIKE: overridden from workspace to drop the `signal` feature (Unix
+# signal machinery that pulls tokio/net -> mio and has no emscripten backend).
+# `signal` is only used by the embedded sync server; re-added under `sync-server`.
+tokio = { version = "1.45", features = ["fs", "rt-multi-thread", "macros", "io-util", "time", "sync"] }
 tokio-util.workspace = true
 tower-http.workspace = true
 tracing.workspace = true
diff --git a/rslib/src/backend/mod.rs b/rslib/src/backend/mod.rs
index 1dbc57a..cf32205 100644
--- a/rslib/src/backend/mod.rs
+++ b/rslib/src/backend/mod.rs
@@ -177,7 +177,14 @@ impl Backend {
         let mut web_client = self.web_client.lock().unwrap();
 
         web_client
-            .get_or_insert_with(|| Client::builder().http1_only().build().unwrap())
+            .get_or_insert_with(|| {
+                let builder = Client::builder();
+                // WASM SPIKE: reqwest's wasm fetch backend ClientBuilder has no
+                // `http1_only()`; the browser controls the HTTP version.
+                #[cfg(not(target_family = "wasm"))]
+                let builder = builder.http1_only();
+                builder.build().unwrap()
+            })
             .clone()
     }
 
