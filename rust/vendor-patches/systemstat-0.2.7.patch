diff -ruN --ex a/systemstat/src/platform/emscripten.rs b/systemstat/src/platform/emscripten.rs
--- a/systemstat/src/platform/emscripten.rs	1970-01-01 01:00:00
+++ b/systemstat/src/platform/emscripten.rs	2026-07-10 23:55:50
@@ -0,0 +1,83 @@
+//! WASM SPIKE (CleanAnki) stub platform for `wasm32-unknown-emscripten`.
+//!
+//! Emscripten has no host system-metrics backend, and systemstat 0.2.7 ships no
+//! implementation for `target_os = "emscripten"` (only unix/windows variants),
+//! so `PlatformImpl` is otherwise undefined and the crate fails to compile.
+//!
+//! systemstat is pulled in transitively only by `burn-train` (via `fsrs`), which
+//! the wasm bridge never exercises at runtime, so every query simply returns an
+//! "unsupported" error. This exists purely so the crate compiles + links.
+
+use std::collections::BTreeMap;
+use std::io;
+
+use crate::data::*;
+use crate::platform::common::Platform;
+
+fn unsupported<T>() -> io::Result<T> {
+    Err(io::Error::new(
+        io::ErrorKind::Unsupported,
+        "systemstat: unsupported on wasm32-unknown-emscripten",
+    ))
+}
+
+pub struct PlatformImpl;
+
+impl Platform for PlatformImpl {
+    fn new() -> Self {
+        PlatformImpl
+    }
+
+    fn cpu_load(&self) -> io::Result<DelayedMeasurement<Vec<CPULoad>>> {
+        unsupported()
+    }
+
+    fn load_average(&self) -> io::Result<LoadAverage> {
+        unsupported()
+    }
+
+    fn memory(&self) -> io::Result<Memory> {
+        unsupported()
+    }
+
+    fn swap(&self) -> io::Result<Swap> {
+        unsupported()
+    }
+
+    // The trait requires overriding one of `uptime`/`boot_time`.
+    fn uptime(&self) -> io::Result<Duration> {
+        unsupported()
+    }
+
+    fn battery_life(&self) -> io::Result<BatteryLife> {
+        unsupported()
+    }
+
+    fn on_ac_power(&self) -> io::Result<bool> {
+        unsupported()
+    }
+
+    fn mounts(&self) -> io::Result<Vec<Filesystem>> {
+        unsupported()
+    }
+
+    fn block_device_statistics(&self) -> io::Result<BTreeMap<String, BlockDeviceStats>> {
+        unsupported()
+    }
+
+    fn networks(&self) -> io::Result<BTreeMap<String, Network>> {
+        unsupported()
+    }
+
+    fn network_stats(&self, _interface: &str) -> io::Result<NetworkStats> {
+        unsupported()
+    }
+
+    fn cpu_temp(&self) -> io::Result<f32> {
+        unsupported()
+    }
+
+    fn socket_stats(&self) -> io::Result<SocketStats> {
+        unsupported()
+    }
+}
